{
  "name": "gemini",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:og": "node scripts/gen-og.mjs",
    "build": "vue-tsc && vite build && vite build --ssr src/render.ts --outDir dist-server && node scripts/prerender.mjs",
